{
  "compilerOptions": {
    "skipLibCheck": true,
    "target": "es2023",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "baseUrl": "./",
    "module": "esnext",
    "types": [
      "vite/client"
    ],
    "paths": {
      "@shared/*": [
        "src/shared/*"
      ]
    },
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src"
  ]
}